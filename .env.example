# обязательное
NODE_ENV=production
PORT=3000
SESSION_SECRET=replace_with_long_random_string

# admin (можешь поменять)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# пути для хостинга (Timeweb)
DATA_DIR=/tmp/generatornumbers
DB_PATH=/tmp/generatornumbers/database.sqlite
SESSION_PATH=/tmp/sessions

# если фронт на другом домене (опционально)
# CLIENT_URL=https://your-frontend-domain.com
